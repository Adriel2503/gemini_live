# === Gemini API ===
GEMINI_API_KEY=your_api_key_here

# === Modelo ===
# En la interfaz web el modelo se elige desde el desplegable. Esta variable es
# el DEFAULT: lo que usa el CLI y lo que aparece preseleccionado en la web.
# La lista de modelos elegibles esta en ALLOWED_MODELS (src/gemini_live_demo/web/server.py).
GEMINI_MODEL=gemini-2.5-flash-native-audio-latest
# ID canonico documentado (mas robusto que el alias -latest):
#   GEMINI_MODEL=gemini-2.5-flash-native-audio-preview-12-2025
# Alternativa (preview): GEMINI_MODEL=gemini-3.1-flash-live-preview

# === Voz / idioma ===
GEMINI_VOICE_NAME=Aoede
GEMINI_LANGUAGE=es-US

# === Audio ===
GEMINI_INPUT_SAMPLE_RATE=16000
GEMINI_OUTPUT_SAMPLE_RATE=24000
GEMINI_CHANNELS=1
GEMINI_CHUNK_MS=20

# === Deteccion de voz (VAD, modo continuo) ===
GEMINI_CONTINUOUS_MODE=true
GEMINI_VAD_SILENCE_MS=700
GEMINI_VAD_PREFIX_MS=200

# === Cola de audio (diagnostico, CLI) ===
GEMINI_AUDIO_QUEUE_MAX_CHUNKS=200
GEMINI_AUDIO_QUEUE_LOG_EVERY_CHUNKS=250
GEMINI_AUDIO_QUEUE_WARN_CHUNKS=25

# === Metricas / grabacion (CLI) ===
GEMINI_METRICS_CSV=true
GEMINI_METRICS_DIR=metrics
GEMINI_MIN_RECORD_SECONDS=0.5
GEMINI_SILENCE_RMS_THRESHOLD=0.01
# GEMINI_NO_PLAYBACK=false
# GEMINI_RECORD_OUTPUT_WAV=false
# GEMINI_OUTPUT_WAV_DIR=recordings

# === Compresion de contexto (sesiones largas) ===
GEMINI_CONTEXT_TRIGGER_TOKENS=16000
GEMINI_CONTEXT_TARGET_TOKENS=8000

# === Logs ===
# INFO = señal limpia (conexion, modelo, micro, respuesta+latencia, turnos).
# DEBUG = diagnostico detallado (stats por-chunk, VAD, resumption handle...).
GEMINI_LOG_LEVEL=INFO

# === Servidor web (opcional) ===
# Donde escucha `gemini-live-web`. Docker/Dokploy usan 0.0.0.0:8000.
# HOST=0.0.0.0
# PORT=8000
# Solo para dev: fuerza la carpeta frontend/ si no está en cwd ni junto al
# repo (normalmente no hace falta, hay fallbacks automáticos).
# GEMINI_FRONTEND_DIR=frontend

# === Llamadas telefonicas (opcional, bridge de Asterisk) ===
# Si se configura, la web muestra la seccion "Llamar" y POST /call se proxyea
# al servicio asterisk-bridge (Go). Sin BRIDGE_URL, la seccion no aparece.
# El token debe coincidir con BRIDGE_TOKEN en /etc/gemini-bridge.env del
# servidor Asterisk; nunca se expone al navegador.
# BRIDGE_URL=http://64.23.133.231:9094
# BRIDGE_TOKEN=CHANGE_ME

# === Agente Voz (opcional, diagnostico del gateway agente_voz) ===
# Si se configura, la web muestra la pestaña "🤖 Agente Voz": el navegador
# habla directo contra agente_voz (prompt/tools/tipificacion reales de la
# plantilla), sin telefono y sin pasar por el Gemini propio de esta demo.
# POST /agente-voz/sesion arma la sesion con este token; nunca se expone al
# navegador (mismo patron que BRIDGE_TOKEN).
# AGENTE_VOZ_URL=https://agente.ai-you.io/v1/agente-voz
# AGENTE_VOZ_TOKEN=CHANGE_ME
# AGENTE_VOZ_ID_PLANTILLA=139

# El system prompt NO se configura aqui: vive hardcodeado en core/config.py
# (Settings.prompt). Solo define GEMINI_SYSTEM_PROMPT si necesitas sobreescribirlo.

# === Saludo inicial (Gemini habla primero) ===
# Si esta en true, al abrir la sesion se dispara un turno de texto (no pasa
# por el VAD) para que Gemini salude antes de que el usuario diga nada.
# GEMINI_GREET_FIRST=true
# GEMINI_GREETING_TRIGGER=[Inicio de sesion: saluda brevemente y pregunta en que puedes ayudar]

# === Transcripcion (texto del usuario y de la IA) ===
# Por defecto ON: activa input+output transcription de la Live API. El texto
# del usuario llega como {"type":"user_text"} y el de la IA como {"type":"text"}.
# En las llamadas telefonicas el bridge Go lo loguea como USUARIO:/IA: por UUID.
# El input transcription no cuesta tokens extra. Poner en false para desactivar.
# GEMINI_TRANSCRIBE=false
